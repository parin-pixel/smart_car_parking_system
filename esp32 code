client.println("<div class='slot " + String(ir4val==0?"full":"empty") + "'>");
client.println("<div class='label'>Slot 04</div>");
client.println(ir4val==0 ? fullCar : emptyCar);
client.println("<span class='badge'>" + slot4stat + "</span></div>");

// Count available slots
int available = (ir1val!=0) + (ir2val!=0) + (ir3val!=0) + (ir4val!=0);
int occupied  = 4 - available;

client.println("</div>");
client.println("<div class='summary'>");
client.println("<span><span class='dot'></span>Live</span>");
