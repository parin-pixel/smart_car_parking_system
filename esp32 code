#include <WiFi.h>
#define IR1 14
#define IR2 18
#define IR3 34
#define IR4 19

String slot1stat;
String slot2stat;
String slot3stat;
String slot4stat;
int ir1val;
int ir2val;
int ir3val;
int ir4val;

const char *ssid = "myESP";
const char *password = "12345678";
WiFiServer Server(80);

void setup() {
  // put your setup code here, to run once:
Serial.begin(115200);
pinMode(IR1,INPUT);
pinMode(IR2,INPUT);
pinMode(IR3,INPUT);
pinMode(IR4,INPUT);

WiFi.begin(ssid,password);
Serial.print("Connecting..");
while(WiFi.status() != WL_CONNECTED){
  delay(500);
  Serial.println("."); 
}
Serial.println(WiFi.localIP());

Server.begin();
}

void loop() {
  // put your main code here, to run repeatedly:
ir1val = digitalRead(IR1);
ir2val = digitalRead(IR2);
ir3val = digitalRead(IR3);
ir4val = digitalRead(IR4);

if(ir1val == 0){
  slot1stat = "FULL";
}
else{
  slot1stat = "EMPTY";
}
if(ir2val == 0){
  slot2stat = "FULL";
}
else{
  slot2stat = "EMPTY";
}
if(ir3val == 0){
  slot3stat = "FULL";
}
else{
  slot3stat = "EMPTY";
}
if(ir4val == 0){
  slot4stat = "FULL";
}
else{
  slot4stat = "EMPTY";
}
WiFiClient client = Server.available();
if(client){
  String request = client.readStringUntil('\r');
  client.flush();

  client.println("HTTP/1.1 200 OK");
  client.println("Content-Type: text/html");
  client.println();
  client.println(R"rawliteral(
