#include <Servo.h>
#include <LiquidCrystal.h>
Servo myservo;
LiquidCrystal lcd(12,11,8,7,6,5);
#define irpin 13
int irval;
void setup() {
  // put your setup code here, to run once:
Serial.begin(9600);
pinMode(irpin,INPUT);
myservo.attach(2);
myservo.write(0);

lcd.clear();
lcd.begin(16,2);

}

void loop() {
  // put your main code here, to run repeatedly:
lcd.setCursor(0,0);
irval = digitalRead(irpin);

if(irval==0){
  
  lcd.print("WELCOME");
  delay(2000);
  lcd.clear();
  lcd.print("SCAN THIS QR");
  
  myservo.write(90);
}
else{
  lcd.clear();
  myservo.write(0);

}
}
